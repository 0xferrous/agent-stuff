{
  "name": "pi-extensions",
  "version": "1.0.0",
  "description": "Custom pi extensions",
  "type": "module",
  "private": true,
  "dependencies": {
    "@earendil-works/pi-ai": "^0.81.1",
    "@earendil-works/pi-coding-agent": "^0.81.1",
    "@earendil-works/pi-tui": "^0.81.1",
    "just-bash": "^2.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types tests/**/*.test.ts",
    "test:bash-sane": "node --test --experimental-strip-types tests/bash-sane.test.ts"
  },
  "pi": {
    "extensions": [
      "extensions",
      "extensions/vendored",
      "extensions/codex-web-search"
    ],
    "skills": [
      "skills"
    ],
    "prompts": [
      "prompts"
    ],
    "themes": [
      "themes"
    ]
  }
}
